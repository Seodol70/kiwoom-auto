# 이 파일을 복사해서 .env 로 저장하고 실제 값을 채우세요.
# .env 는 절대 Git에 커밋하지 마세요.

KIWOOM_USER_ID=your_id_here
KIWOOM_PASSWORD=your_password_here
KIWOOM_CERT_PASSWORD=your_cert_password_here
KIWOOM_IS_MOCK=true
KIWOOM_ACCOUNT=1234567890

# 텔레그램 알림 설정 (BotFather로 봇 생성 후 입력)
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321
